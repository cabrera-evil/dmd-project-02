  <Source dwd:design-time-name="cd9cd893-6d07-4ab8-9379-262eedfc8966">
    <DataSourceViewID>Dmd-project-02</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="1a5881ac-a961-41d8-8d73-f11178a8914a">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;   
CREATE MEMBER CURRENTCUBE.[Measures].[Net Margin %]
 AS IIF([Measures].[Sales] = 0, NULL, [Measures].[Profit] / [Measures].[Sales]), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Financials'; 
CREATE MEMBER CURRENTCUBE.[Measures].[Discount Percentage]
 AS IIF([Measures].[Gross Sales] = 0, NULL, [Measures].[Discounts] / [Measures].[Gross Sales]), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Financials'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Previous Year Sales]
 AS (ParallelPeriod(
    [Dim Date].[Calendar].[Year], 
    1, 
    [Dim Date].[Calendar].CurrentMember
), [Measures].[Sales]), 
FORMAT_STRING = "Currency", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Financials'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Growth %]
 AS IIF(IsEmpty([Measures].[Previous Year Sales]) OR [Measures].[Previous Year Sales] = 0, 
    NULL, 
    ([Measures].[Sales] - [Measures].[Previous Year Sales]) / [Measures].[Previous Year Sales]
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Financials'  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="ee265844-a590-41e4-ba1c-af2c8c5b8e40">
      <ID>KPI</ID>
      <Name>KPI_Margen_Neto</Name>
      <AssociatedMeasureGroupID>Fact Financials</AssociatedMeasureGroupID>
      <Value>[Measures].[Net Margin %]</Value>
      <Goal>0.15</Goal>
      <Status>IIF([Measures].[Margen Neto %] &gt;= 0.15, 1, 
    IIF([Measures].[Margen Neto %] &gt;= 0.10, 0, -1)
)</Status>
      <Trend>IIF([Measures].[Margen Neto %] &gt; (ParallelPeriod([Dim Date].[Calendar].[Year], 1, [Dim Date].[Calendar].CurrentMember), [Measures].[Margen Neto %]), 1, -1)</Trend>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Gauge - Ascending</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>